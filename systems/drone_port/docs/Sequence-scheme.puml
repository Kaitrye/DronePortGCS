@startuml
title Sequence Diagram: Посадка, диагностика и зарядка дрона в Дронопорте

autonumber

participant "Дрон (БВС)" as Drone
participant "RobotSystem" as Robot
participant "SystemBus" as Bus
participant "DroneportOrchestrator" as Orchestrator
participant "PortManager" as PortMgr
participant "DroneRegistry" as Registry
participant "PowerHealthManager" as Power
participant "StateStore" as Store
participant "DroneTelemetry" as Telemetry

== Запрос посадки ==

Drone -> Robot: Телеметрия: battery=15%, status=low_battery
Robot -> Bus: publish(REQUEST_LANDING_SLOT, {drone_id: "D-001"})
Bus -> Orchestrator: deliver(REQUEST_LANDING_SLOT)

Orchestrator -> PortMgr: request_landing_slot("D-001")
PortMgr -> Store: get_drone_meta("D-001")
Store --> PortMgr: {drone_type: "agricultural", protocol: "MAVLink"}

PortMgr -> Store: get_port("P-01")
Store --> PortMgr: {status: "free", maintenance_mode: "false"}

PortMgr -> PortMgr: _validate_drone_compatibility("D-001", "P-01")
PortMgr --> Orchestrator: {status: "slot_assigned", port_id: "P-01", corridor: {...}}

Orchestrator -> Bus: publish(LANDING_SLOT_ASSIGNED, {drone_id: "D-001", port_id: "P-01"})
Bus -> Robot: deliver(LANDING_SLOT_ASSIGNED)
Robot -> Drone: команда: land_at_port_id("P-01", corridor)

== Посадка и диагностика ==

Drone -> Orchestrator: Телеметрия: landed at P-01
Orchestrator -> Bus: publish(DOCK, {drone_id: "D-001"})

Orchestrator -> Power: run_post_landing_diagnostics("D-001")
Power -> Store: get_drone("D-001")
Store --> Power: {battery_level: "15.0", status: "landed"}

Power -> Telemetry: query_drone_self_diagnostics("D-001")
Telemetry --> Power: {motors: "ok", gps: "strong", temp: 45°C}

Power --> Orchestrator: {status: "diagnostics.failed", issues: ["battery_critical"]}

Orchestrator -> Registry: register_drone("D-001", battery=15.0, port="P-01")
Registry -> Store: save_drone("D-001", {...})
Registry -> Store: register_drone_meta("D-001", specs)

Registry --> Orchestrator: {status: "registered"}

== Автоматическая зарядка ==

Orchestrator -> Power: auto_start_charging_if_needed("D-001")
Power -> Store: get_drone("D-001")
Store --> Power: {battery_level: "15.0"}

Power -> Power: battery < 80% → start charging
Power -> Store: save_drone("D-001", {status: "charging", charging_power_w: "500"})

Power --> Orchestrator: {status: "charging.started", drone_id: "D-001"}

Orchestrator -> Bus: publish(CHARGING_STARTED, {drone_id: "D-001", port_id: "P-01"})

== Мониторинг зарядки ==

loop Every 5 minutes
    Power -> Store: get_drone("D-001")
    Store --> Power: {battery_level: "45.0"}
    
    Power -> Power: calculate_charging_progress()
    
    Power -> Store: save_drone("D-001", {battery_level: "45.0"})
    
    Power -> Bus: publish(CHARGING_PROGRESS, {drone_id: "D-001", battery: "45%"})
end

== Подготовка к взлету ==

Robot -> Bus: publish(PREFLIGHT_CHECK, {drone_id: "D-001", min_battery: "90%"})
Bus -> Orchestrator: deliver(PREFLIGHT_CHECK)

Orchestrator -> Store: get_drone("D-001")
Store --> Orchestrator: {battery_level: "92.0", status: "charging"}

Orchestrator -> Power: charge_to_threshold("D-001", min_battery=90, current=92)
Power --> Orchestrator: {status: "charge.not_required", battery_level: 92.0}

Orchestrator -> Bus: publish(PREFLIGHT_OK, {drone_id: "D-001", ready: true})

== Взлет ==

Robot -> Bus: publish(RELEASE_FOR_TAKEOFF, {drone_id: "D-001"})
Bus -> Orchestrator: deliver(RELEASE_FOR_TAKEOFF)

Orchestrator -> PortMgr: release_for_takeoff("D-001")
PortMgr -> Store: get_drone("D-001")
Store --> PortMgr: {port_id: "P-01"}

PortMgr -> Store: save_port("P-01", {drone_id: "", status: "free"})
PortMgr -> Store: delete_drone("D-001")

PortMgr --> Orchestrator: {status: "release_ack", drone_id: "D-001"}

Orchestrator -> Bus: publish(TAKEOFF_ALLOWED, {drone_id: "D-001", port_id: "P-01"})
Bus -> Robot: deliver(TAKEOFF_ALLOWED)

Robot -> Drone: команда: takeoff_allowed()

Drone -> Orchestrator: Телеметрия: takeoff_confirmed

Orchestrator -> Bus: publish(DRONE_DEPARTED, {drone_id: "D-001", port_id: "P-01"})

note right of Orchestrator
  DroneportOrchestrator:
  • Маршрутизирует команды
  • Координирует компоненты
  • Агрегирует данные для отчётов
  • НЕ содержит бизнес-логику
end note

@enduml