# Настройки инфраструктуры брокера
BROKER_TYPE=mqtt

KAFKA_PORT=9092
KAFKA_INTERNAL_PORT=29092
MQTT_PORT=1883

# Админ — всегда есть в Kafka.
ADMIN_USER=admin
ADMIN_PASSWORD=admin_secret_123

DOCKER_NETWORK=drones_net

# Идентификатор инстанса системы
INSTANCE_ID=1

# Журнал безопасности — отправка в Инфопанель (команда 4).
# Реальные ключи хранить в docker/.env (он в .gitignore), сюда коммитить пустыми.
INFOPANEL_URL=https://droneanalytics.ourpaint.ru/api/log/event
INFOPANEL_DRONE_PORT_API_KEY=
INFOPANEL_GCS_API_KEY=
INFOPANEL_BATCH_SIZE=50
INFOPANEL_FLUSH_INTERVAL_S=5.0
INFOPANEL_MAX_RETRIES=5
INFOPANEL_VERIFY_TLS=true